{
  "manifest_version": 3,
  "name": "Briefly",
  "version": "1.0.0",
  "description": "Summarize articles from your current tab.",
  "action": {
    "default_title": "Briefly",
    "default_popup": "index.html"
  },
  "permissions": ["activeTab", "tabs", "storage"],
  "host_permissions": ["<all_urls>"],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
